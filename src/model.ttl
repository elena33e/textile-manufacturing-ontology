                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty extended-dns:setting-for ;
                                            owl:someValuesFrom [ owl:intersectionOf ( ont-tesut-covoare:AplicareCuloare
                                                                                      ont-tesut-covoare:Reteta
                                                                                    ) ;
                                                                 rdf:type owl:Class
                                                               ]
                                          ] .


