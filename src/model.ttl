@prefix : <http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix spatial: <http://www.loa-cnr.it/ontologies/SpatialRelations.owl#> .
@prefix temporal: <http://www.loa-cnr.it/ontologies/TemporalRelations.owl#> .
@prefix dolce-lite: <http://www.loa-cnr.it/ontologies/DOLCE-Lite.owl#> .
@prefix extended-dns: <http://www.loa-cnr.it/ontologies/ExtendedDnS.owl#> .
@prefix ont-tesut-covoare: <http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#> .
@base <http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#> .

<http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare> rdf:type owl:Ontology ;
                                                                            owl:imports <http://www.loa-cnr.it/ontologies/DOLCE-Lite.owl> ,
                                                                                        <http://www.loa-cnr.it/ontologies/ExtendedDnS.owl> ,
                                                                                        <http://www.loa-cnr.it/ontologies/SpatialRelations.owl> ,
                                                                                        <http://www.loa-cnr.it/ontologies/TemporalRelations.owl> .

#################################################################
#    Annotation properties
#################################################################

###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.loa-cnr.it/ontologies/DOLCE-Lite.owl#immediate-relation-i
dolce-lite:immediate-relation-i rdfs:subPropertyOf dolce-lite:part .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#elimina
ont-tesut-covoare:elimina rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf owl:topObjectProperty ;
                          rdfs:domain ont-tesut-covoare:Curatare ;
                          rdfs:range ont-tesut-covoare:Impuritate .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#provine
ont-tesut-covoare:provine rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf owl:topObjectProperty ;
                          rdfs:domain dolce-lite:amount-of-matter ;
                          rdfs:range dolce-lite:physical-object .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#reprezentat-fizic-pe
ont-tesut-covoare:reprezentat-fizic-pe rdf:type owl:ObjectProperty ;
                                       rdfs:subPropertyOf dolce-lite:generically-dependent-on ;
                                       rdfs:domain ont-tesut-covoare:Model ;
                                       rdfs:range extended-dns:material-artifact ;
                                       rdfs:comment "Relație care indică faptul că un design/model abstract este reprezentat (desenat, transpus) pe un suport fizic concret." .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#sustine
ont-tesut-covoare:sustine rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf dolce-lite:weak-connection ;
                          rdfs:domain ont-tesut-covoare:Razboi ;
                          rdfs:range ont-tesut-covoare:Tesatura .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#urmeaza
ont-tesut-covoare:urmeaza rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf extended-dns:references ;
                          rdfs:domain [ rdf:type owl:Class ;
                                        owl:unionOf ( ont-tesut-covoare:Extragere
                                                      ont-tesut-covoare:Vopsire
                                                    )
                                      ] ;
                          rdfs:range ont-tesut-covoare:Reteta .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#AgentSpalare
ont-tesut-covoare:AgentSpalare rdf:type owl:Class ;
                               rdfs:subClassOf dolce-lite:amount-of-matter .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#AlegereRazboi
ont-tesut-covoare:AlegereRazboi rdf:type owl:Class ;
                                rdfs:subClassOf extended-dns:task .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Ales
ont-tesut-covoare:Ales rdf:type owl:Class ;
                       rdfs:subClassOf ont-tesut-covoare:TehnicaIntroducere .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Animal
ont-tesut-covoare:Animal rdf:type owl:Class ;
                         rdfs:subClassOf extended-dns:agentive-physical-object .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#AplicareCuloare
ont-tesut-covoare:AplicareCuloare rdf:type owl:Class ;
                                  rdfs:subClassOf dolce-lite:process .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Aspect
ont-tesut-covoare:Aspect rdf:type owl:Class ;
                         rdfs:subClassOf dolce-lite:physical-quality .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Batatura
ont-tesut-covoare:Batatura rdf:type owl:Class ;
                           rdfs:subClassOf extended-dns:material-artifact ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty dolce-lite:specific-constant-constituent-of ;
                                             owl:allValuesFrom ont-tesut-covoare:Covor
                                           ] .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Batut
ont-tesut-covoare:Batut rdf:type owl:Class ;
                        rdfs:subClassOf extended-dns:action .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Bumbac
ont-tesut-covoare:Bumbac rdf:type owl:Class ;
                         rdfs:subClassOf ont-tesut-covoare:Fibra .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Canepa
ont-tesut-covoare:Canepa rdf:type owl:Class ;
                         rdfs:subClassOf ont-tesut-covoare:Planta .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#CapatCovor
ont-tesut-covoare:CapatCovor rdf:type owl:Class ;
                             rdfs:subClassOf dolce-lite:dependent-place ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty dolce-lite:host ;
                                               owl:someValuesFrom ont-tesut-covoare:CapatCovor
                                             ] .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#CartonFizic
ont-tesut-covoare:CartonFizic rdf:type owl:Class ;
                              rdfs:subClassOf ont-tesut-covoare:SuportModel ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty dolce-lite:generic-constituent ;
                                                owl:allValuesFrom ont-tesut-covoare:Hartie
                                              ] .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Chilim
ont-tesut-covoare:Chilim rdf:type owl:Class ;
                         rdfs:subClassOf ont-tesut-covoare:TehnicaIntroducere .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#CoajaFruct
ont-tesut-covoare:CoajaFruct rdf:type owl:Class ;
                             rdfs:subClassOf ont-tesut-covoare:PartePlanta ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty dolce-lite:part-of ;
                                               owl:allValuesFrom ont-tesut-covoare:Fruct
                                             ] .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#CoajaFructColorant
ont-tesut-covoare:CoajaFructColorant rdf:type owl:Class ;
                                     rdfs:subClassOf ont-tesut-covoare:ExtractPlanta .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Colorant
ont-tesut-covoare:Colorant rdf:type owl:Class ;
                           rdfs:subClassOf extended-dns:communication-event ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty extended-dns:played-by ;
                                             owl:someValuesFrom ont-tesut-covoare:SubstantaColorant
                                           ] .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#ColorantNatural
ont-tesut-covoare:ColorantNatural rdf:type owl:Class ;
                                  rdfs:subClassOf ont-tesut-covoare:Colorant ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty extended-dns:played-by ;
                                                    owl:someValuesFrom ont-tesut-covoare:ExtractPlanta
                                                  ] .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Colorare
ont-tesut-covoare:Colorare rdf:type owl:Class ;
                           rdfs:subClassOf extended-dns:task ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty extended-dns:defined-by ;
                                             owl:someValuesFrom ont-tesut-covoare:Reteta
                                           ] .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Copac
ont-tesut-covoare:Copac rdf:type owl:Class ;
                        rdfs:subClassOf ont-tesut-covoare:Planta .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Covor
ont-tesut-covoare:Covor rdf:type owl:Class ;
                        rdfs:subClassOf ont-tesut-covoare:Tesatura .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Culoare
ont-tesut-covoare:Culoare rdf:type owl:Class ;
                          rdfs:subClassOf dolce-lite:physical-quality ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty dolce-lite:has-quale ;
                                            owl:allValuesFrom ont-tesut-covoare:Nuanta
                                          ] .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Curatare
ont-tesut-covoare:Curatare rdf:type owl:Class ;
                           rdfs:subClassOf extended-dns:action .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Daracit
ont-tesut-covoare:Daracit rdf:type owl:Class ;
                          rdfs:subClassOf extended-dns:task .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Daracitor
ont-tesut-covoare:Daracitor rdf:type owl:Class ;
                            rdfs:subClassOf ont-tesut-covoare:UnealtaTextila .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#DaracitorManual
ont-tesut-covoare:DaracitorManual rdf:type owl:Class ;
                                  rdfs:subClassOf ont-tesut-covoare:Daracitor .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#DaracitorMecanic
ont-tesut-covoare:DaracitorMecanic rdf:type owl:Class ;
                                   rdfs:subClassOf ont-tesut-covoare:Daracitor .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Decor
ont-tesut-covoare:Decor rdf:type owl:Class ;
                        rdfs:subClassOf dolce-lite:physical-quality .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Desenare
ont-tesut-covoare:Desenare rdf:type owl:Class ;
                           rdfs:subClassOf dolce-lite:process .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#DesignCovor
ont-tesut-covoare:DesignCovor rdf:type owl:Class ;
                              rdfs:subClassOf extended-dns:constitutive-description ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty extended-dns:defines ;
                                                owl:someValuesFrom ont-tesut-covoare:GhidVizual
                                              ] .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Desprindere
ont-tesut-covoare:Desprindere rdf:type owl:Class ;
                              rdfs:subClassOf extended-dns:action .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Detergent
ont-tesut-covoare:Detergent rdf:type owl:Class ;
                            rdfs:subClassOf ont-tesut-covoare:AgentSpalare .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Dinte
ont-tesut-covoare:Dinte rdf:type owl:Class ;
                        rdfs:subClassOf extended-dns:material-artifact .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#DinteDaracitor
ont-tesut-covoare:DinteDaracitor rdf:type owl:Class ;
                                 rdfs:subClassOf ont-tesut-covoare:Dinte ,
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty dolce-lite:generic-constituent ;
                                                   owl:allValuesFrom ont-tesut-covoare:Otel
                                                 ] .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#DintePieptene
ont-tesut-covoare:DintePieptene rdf:type owl:Class ;
                                rdfs:subClassOf ont-tesut-covoare:Dinte .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#ExecutieDecor
ont-tesut-covoare:ExecutieDecor rdf:type owl:Class ;
                                rdfs:subClassOf extended-dns:task .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#ExtractPlanta
ont-tesut-covoare:ExtractPlanta rdf:type owl:Class ;
                                rdfs:subClassOf ont-tesut-covoare:SubstantaColorant .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Extragere
ont-tesut-covoare:Extragere rdf:type owl:Class ;
                            rdfs:subClassOf extended-dns:task .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Femeie
ont-tesut-covoare:Femeie rdf:type owl:Class ;
                         rdfs:subClassOf ont-tesut-covoare:Persoana .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Fibra
ont-tesut-covoare:Fibra rdf:type owl:Class ;
                        rdfs:subClassOf dolce-lite:amount-of-matter .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#FibraCanepa
ont-tesut-covoare:FibraCanepa rdf:type owl:Class ;
                              rdfs:subClassOf ont-tesut-covoare:Fibra ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty ont-tesut-covoare:provine ;
                                                owl:allValuesFrom ont-tesut-covoare:Canepa
                                              ] .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Fier
ont-tesut-covoare:Fier rdf:type owl:Class ;
                       rdfs:subClassOf dolce-lite:amount-of-matter .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Finisare
ont-tesut-covoare:Finisare rdf:type owl:Class ;
                           rdfs:subClassOf extended-dns:task .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Fir
ont-tesut-covoare:Fir rdf:type owl:Class ;
                      rdfs:subClassOf extended-dns:material-artifact .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#FirTors
ont-tesut-covoare:FirTors rdf:type owl:Class ;
                          rdfs:subClassOf ont-tesut-covoare:Fir ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty dolce-lite:has-quality ;
                                            owl:someValuesFrom ont-tesut-covoare:Procesat
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty extended-dns:parametrized-by ;
                                            owl:someValuesFrom ont-tesut-covoare:Grosime
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty dolce-lite:specific-constant-constituent-of ;
                                            owl:allValuesFrom ont-tesut-covoare:Covor
                                          ] .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#FirUrzeala
ont-tesut-covoare:FirUrzeala rdf:type owl:Class ;
                             rdfs:subClassOf ont-tesut-covoare:Fir .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#FirVopsit
ont-tesut-covoare:FirVopsit rdf:type owl:Class ;
                            rdfs:subClassOf ont-tesut-covoare:Fir ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty dolce-lite:has-quality ;
                                              owl:someValuesFrom [ owl:intersectionOf ( ont-tesut-covoare:Culoare
                                                                                        ont-tesut-covoare:Procesat
                                                                                      ) ;
                                                                   rdf:type owl:Class
                                                                 ]
                                            ] .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#FixareUrzeala
ont-tesut-covoare:FixareUrzeala rdf:type owl:Class ;
                                rdfs:subClassOf extended-dns:action ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty dolce-lite:participant ;
                                                  owl:someValuesFrom [ owl:intersectionOf ( ont-tesut-covoare:Sul
                                                                                            ont-tesut-covoare:Urzeala
                                                                                          ) ;
                                                                       rdf:type owl:Class
                                                                     ]
                                                ] .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Foarfeca
ont-tesut-covoare:Foarfeca rdf:type owl:Class ;
                           rdfs:subClassOf extended-dns:material-artifact .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Forfecare
ont-tesut-covoare:Forfecare rdf:type owl:Class ;
                            rdfs:subClassOf extended-dns:action .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Franj
ont-tesut-covoare:Franj rdf:type owl:Class ;
                        rdfs:subClassOf extended-dns:material-artifact .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Franjurare
ont-tesut-covoare:Franjurare rdf:type owl:Class ;
                             rdfs:subClassOf dolce-lite:process .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Fruct
ont-tesut-covoare:Fruct rdf:type owl:Class ;
                        rdfs:subClassOf extended-dns:non-agentive-physical-object ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty dolce-lite:part-of ;
                                          owl:allValuesFrom ont-tesut-covoare:Planta
                                        ] .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Fus
ont-tesut-covoare:Fus rdf:type owl:Class ;
                      rdfs:subClassOf ont-tesut-covoare:UnealtaTors .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Gherghef
ont-tesut-covoare:Gherghef rdf:type owl:Class ;
                           rdfs:subClassOf ont-tesut-covoare:Razboi ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty ont-tesut-covoare:sustine ;
                                             owl:someValuesFrom ont-tesut-covoare:Tesatura
                                           ] .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#GhidVizual
ont-tesut-covoare:GhidVizual rdf:type owl:Class ;
                             rdfs:subClassOf extended-dns:role ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty extended-dns:played-by ;
                                               owl:someValuesFrom ont-tesut-covoare:ModelCarton
                                             ] .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Gros
ont-tesut-covoare:Gros rdf:type owl:Class ;
                       rdfs:subClassOf ont-tesut-covoare:Aspect .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Grosime
ont-tesut-covoare:Grosime rdf:type owl:Class ;
                          rdfs:subClassOf extended-dns:parameter ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty extended-dns:valued-by ;
                                            owl:someValuesFrom ont-tesut-covoare:SpatiuGrosime
                                          ] .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Hartie
ont-tesut-covoare:Hartie rdf:type owl:Class ;
                         rdfs:subClassOf dolce-lite:amount-of-matter .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#HartieMilimetrica
ont-tesut-covoare:HartieMilimetrica rdf:type owl:Class ;
                                    rdfs:subClassOf ont-tesut-covoare:SuportModel .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Impermeabilitate
ont-tesut-covoare:Impermeabilitate rdf:type owl:Class ;
                                   rdfs:subClassOf dolce-lite:physical-quality .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Impletire
ont-tesut-covoare:Impletire rdf:type owl:Class ;
                            rdfs:subClassOf extended-dns:action .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Impuritate
ont-tesut-covoare:Impuritate rdf:type owl:Class ;
                             rdfs:subClassOf extended-dns:non-agentive-physical-object .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Inflorat
ont-tesut-covoare:Inflorat rdf:type owl:Class ;
                           rdfs:subClassOf ont-tesut-covoare:TehnicaIntroducere .


###  http://www.semanticweb.org/elena/ontologies/2025/11/proces-tesut-covoare#Intindere
ont-tesut-covoare:Intindere rdf:type owl:Class ;
                            rdfs:subClassOf extended-dns:action ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty dolce-lite:participant ;
                                              owl:someValuesFrom [ owl:intersectionOf ( ont-tesut-covoare:Sul
                                                                                        ont-tesut-covoare:Urzeala
                                                                                      ) ;
                                                                   rdf:type owl:Class
                                                                 ]
